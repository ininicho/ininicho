# The NC_DB value format: pg://postgres.postgres.svc.cluster.local:5432?u=postgres&p=PASSWORD&d=nocodb
# bash infra/homelab/scripts/seal-secret.sh nocodb nocodb-db \
#   NC_DB='pg://postgres.postgres.svc.cluster.local:5432?u=postgres&p=<your-password>&d=nocodb' \
#   > infra/homelab/infrastructure/secrets/nocodb-db.yaml
apiVersion: bitnami.com/v1alpha1
kind: SealedSecret
metadata:
  name: nocodb-db
  namespace: nocodb
spec:
  encryptedData:
    NC_DB: <encrypted>
