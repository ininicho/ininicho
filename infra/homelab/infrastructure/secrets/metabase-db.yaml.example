# bash infra/homelab/scripts/seal-secret.sh metabase metabase-db \
#   MB_DB_PASS=<your-postgres-password> \
#   > infra/homelab/infrastructure/secrets/metabase-db.yaml
apiVersion: bitnami.com/v1alpha1
kind: SealedSecret
metadata:
  name: metabase-db
  namespace: metabase
spec:
  encryptedData:
    MB_DB_PASS: <encrypted>
