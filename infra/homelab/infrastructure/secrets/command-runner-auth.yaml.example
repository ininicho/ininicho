# bash infra/homelab/scripts/seal-secret.sh command-runner command-runner-auth \
#   COMMAND_RUNNER_TOKEN=<your-bearer-token> \
#   NTFY_PUBLISH_TOKEN=<your-ntfy-publish-token> \
#   > infra/homelab/infrastructure/secrets/command-runner-auth.yaml
apiVersion: bitnami.com/v1alpha1
kind: SealedSecret
metadata:
  name: command-runner-auth
  namespace: command-runner
spec:
  encryptedData:
    COMMAND_RUNNER_TOKEN: <encrypted>
    NTFY_PUBLISH_TOKEN: <encrypted>
