# bash infra/homelab/scripts/seal-secret.sh minio minio-auth \
#   MINIO_ROOT_USER=<admin-username> \
#   MINIO_ROOT_PASSWORD=<admin-password-min-8-chars> \
#   > infra/homelab/infrastructure/secrets/minio-auth.yaml
apiVersion: bitnami.com/v1alpha1
kind: SealedSecret
metadata:
  name: minio-auth
  namespace: minio
spec:
  encryptedData:
    MINIO_ROOT_USER: <encrypted>
    MINIO_ROOT_PASSWORD: <encrypted>
