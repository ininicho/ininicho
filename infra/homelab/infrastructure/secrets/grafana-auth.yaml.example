# bash infra/homelab/scripts/seal-secret.sh monitoring grafana-auth \
#   GF_SECURITY_ADMIN_PASSWORD=<your-password> \
#   > infra/homelab/infrastructure/secrets/grafana-auth.yaml
apiVersion: bitnami.com/v1alpha1
kind: SealedSecret
metadata:
  name: grafana-auth
  namespace: monitoring
spec:
  encryptedData:
    GF_SECURITY_ADMIN_PASSWORD: <encrypted>
