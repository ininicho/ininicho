# bash infra/homelab/scripts/seal-secret.sh postgres postgres-auth \
#   POSTGRES_PASSWORD=<your-password> \
#   > infra/homelab/infrastructure/secrets/postgres-auth.yaml
apiVersion: bitnami.com/v1alpha1
kind: SealedSecret
metadata:
  name: postgres-auth
  namespace: postgres
spec:
  encryptedData:
    POSTGRES_PASSWORD: <encrypted>
