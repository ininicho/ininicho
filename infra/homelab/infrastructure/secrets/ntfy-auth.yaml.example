# DO NOT commit with real values. Encrypt with seal-secret.sh first.
# bash infra/homelab/scripts/seal-secret.sh ntfy ntfy-auth \
#   NTFY_PUBLISH_TOKEN=<your-publish-token> \
#   NTFY_ADMIN_PASSWORD=<your-admin-password> \
#   > infra/homelab/infrastructure/secrets/ntfy-auth.yaml
apiVersion: bitnami.com/v1alpha1
kind: SealedSecret
metadata:
  name: ntfy-auth
  namespace: ntfy
spec:
  encryptedData:
    NTFY_PUBLISH_TOKEN: <encrypted>
    NTFY_ADMIN_PASSWORD: <encrypted>
