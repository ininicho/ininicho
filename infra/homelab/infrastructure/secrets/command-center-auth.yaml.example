# DATABASE_URL format: postgresql://postgres:<password>@postgres.postgres.svc.cluster.local:5432/ininicho
#
# bash infra/homelab/scripts/seal-secret.sh command-center command-center-auth \
#   DATABASE_URL='postgresql://postgres:<password>@postgres.postgres.svc.cluster.local:5432/ininicho' \
#   COMMAND_CENTER_TOKEN=<token> \
#   NTFY_PUBLISH_TOKEN=<token> \
#   MINIO_ACCESS_KEY=<minio-admin-user> \
#   MINIO_SECRET_KEY=<minio-admin-password> \
#   > infra/homelab/infrastructure/secrets/command-center-auth.yaml
apiVersion: bitnami.com/v1alpha1
kind: SealedSecret
metadata:
  name: command-center-auth
  namespace: command-center
spec:
  encryptedData:
    DATABASE_URL: <encrypted>
    COMMAND_CENTER_TOKEN: <encrypted>
    NTFY_PUBLISH_TOKEN: <encrypted>
    MINIO_ACCESS_KEY: <encrypted>
    MINIO_SECRET_KEY: <encrypted>
